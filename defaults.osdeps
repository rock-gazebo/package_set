simulation/gazebo:
    ubuntu:
        '14.04,14.10,15.04,15.10':
            osdep: gazebo7
        '16.04,16.10,17.04':
            osdep: gazebo8
        '18.04,20.04':
            osdep: gazebo9
        default:
            osdep: gz-sim-10

control/sdformat:
    ubuntu:
        '14.04,14.10,15.04,15.10':
            osdep: sdformat4
        '16.04,16.10,17.04':
            osdep: sdformat5
        '18.04,20.04':
            osdep: sdformat6
        default:
            osdep: sdformat16

